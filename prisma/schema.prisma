// ============================================
// SECURITY MODELS
// ============================================

// Persistent audit log for security events
model AuditLog {
  id         String   @id @default(cuid())
  action     String // e.g., "LOGIN_SUCCESS", "USER_DELETED", "PASSWORD_RESET"
  actorId    String? // User who performed the action
  actorEmail String? // Email of actor (for when user is deleted)
  targetId   String? // Resource affected
  targetType String? // e.g., "User", "Booking", "Payment"
  details    Json? // Additional context (sanitized)
  ip         String? // IP address
  userAgent  String? // Browser/device info
  country    String? // Geo-location country
  severity   String   @default("INFO") // INFO, WARNING, CRITICAL
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@index([severity])
}

// Active user sessions for session management
model UserSession {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique // JWT token hash or session ID
  deviceId     String? // Link to known device
  ip           String?
  userAgent    String?
  country      String?
  city         String?
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  isValid      Boolean  @default(true) // Can be revoked
  createdAt    DateTime @default(now())

  user   User        @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)
  device UserDevice? @relation(fields: [deviceId], references: [id])

  @@index([userId])
  @@index([sessionToken])
  @@index([isValid])
}

// Known user devices for fingerprinting
model UserDevice {
  id          String   @id @default(cuid())
  userId      String
  fingerprint String // Hash of device characteristics
  name        String? // User-friendly name (e.g., "Chrome on Windows")
  browser     String?
  os          String?
  deviceType  String? // desktop, mobile, tablet
  isTrusted   Boolean  @default(false) // User has verified this device
  lastSeenAt  DateTime @default(now())
  lastIp      String?
  lastCountry String?
  createdAt   DateTime @default(now())

  user     User          @relation("UserDevices", fields: [userId], references: [id], onDelete: Cascade)
  sessions UserSession[]

  @@unique([userId, fingerprint])
  @@index([userId])
}

// Email verification tokens
model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation("EmailVerifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ============================================
// SMART LOCK ENUMS
// ============================================

enum SmartLockProvider {
  AUGUST
  YALE
  SCHLAGE
  KWIKSET
  TTLOCK
  NUKI
  GENERIC
}

enum SmartLockAccessType {
  PERMANENT
  TEMPORARY
  ONE_TIME
}

enum SmartLockAccessStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

// ============================================
// SUBSCRIPTION ENUMS
// ============================================

enum SubscriptionTier {
  FREE // Default tier - standard fees
  WORKER_PRO // Lower fees, priority search, badge
  BUSINESS // Bulk discounts, multiple employees
  ENTERPRISE // Custom pricing, dedicated support
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE // Payment failed, grace period
  CANCELED // User canceled, still active until period end
  EXPIRED // Subscription ended
  TRIALING // Free trial period
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

// Worker subscription status (for yearly fee after first job)
enum WorkerSubscriptionStatus {
  NONE // No subscription yet (hasn't completed first job)
  PENDING_PAYMENT // First job completed, waiting for payment (24h window)
  ACTIVE // Paid and active
  EXPIRED // Subscription expired, needs renewal
  SUSPENDED // Didn't pay within 24h, worker is invisible
}

// ============================================
// PROPERTY MANAGEMENT MODEL
// ============================================

model Property {
  id         String   @id @default(cuid())
  ownerId    String
  name       String // e.g., "Beach House", "Main Apartment"
  address    String
  city       String?
  state      String?
  postalCode String?
  country    String?
  latitude   Float?
  longitude  Float?
  size       Int? // Square meters
  rooms      Int? // Number of rooms
  bathrooms  Int? // Number of bathrooms
  notes      String? // Special instructions
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner      User        @relation("UserProperties", fields: [ownerId], references: [id], onDelete: Cascade)
  bookings   Booking[]
  smartLocks SmartLock[]

  @@index([ownerId])
}

// ============================================
// SMART LOCK MODELS
// ============================================

model SmartLock {
  id           String            @id @default(cuid())
  propertyId   String
  name         String // e.g., "Front Door", "Back Door"
  provider     SmartLockProvider
  deviceId     String? // External device ID from provider
  serialNumber String?
  isActive     Boolean           @default(true)
  batteryLevel Int? // 0-100 percentage
  lastSyncAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  property    Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  accessCodes SmartLockAccess[]

  @@index([propertyId])
}

model SmartLockAccess {
  id            String                @id @default(cuid())
  lockId        String
  bookingId     String? // Optional link to booking
  workerId      String?               @map("cleanerId") // Worker who has access
  accessType    SmartLockAccessType   @default(TEMPORARY)
  accessCode    String // The PIN code or access token
  validFrom     DateTime
  validUntil    DateTime? // Null for permanent access
  status        SmartLockAccessStatus @default(ACTIVE)
  usedAt        DateTime? // When the code was first used
  usageCount    Int                   @default(0)
  maxUsage      Int? // Max times code can be used (null = unlimited)
  revokedAt     DateTime?
  revokedReason String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  lock SmartLock @relation(fields: [lockId], references: [id], onDelete: Cascade)

  @@index([lockId])
  @@index([bookingId])
  @@index([workerId], map: "SmartLockAccess_cleanerId_idx")
  @@index([status])
}

// ============================================
// TEAM BOOKING MODEL
// ============================================

model BookingTeamMember {
  id        String   @id @default(cuid())
  bookingId String
  workerId  String   @map("cleanerId")
  isLead    Boolean  @default(false) // Primary worker is the lead
  confirmed Boolean  @default(false) // Team member has accepted
  earnings  Float? // Individual earnings for this team member
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  worker  User    @relation("TeamMemberBookings", fields: [workerId], references: [id])

  @@unique([bookingId, workerId], map: "BookingTeamMember_bookingId_cleanerId_key")
  @@index([bookingId])
  @@index([workerId], map: "BookingTeamMember_cleanerId_idx")
}

// ============================================
// INVOICE MODEL
// ============================================

model Invoice {
  id            String @id @default(cuid())
  invoiceNumber String @unique // INV-2024-0001 format
  bookingId     String @unique
  customerId    String
  workerId      String @map("cleanerId")

  // Invoice details
  subtotal    Float
  tipAmount   Float  @default(0)
  taxRate     Float  @default(0)
  taxAmount   Float  @default(0)
  totalAmount Float
  currency    String @default("USD")

  // Service details (snapshot at invoice time)
  serviceName String
  serviceDate DateTime
  serviceTime String
  duration    Int
  address     String

  // Status
  status String    @default("ISSUED") // ISSUED, PAID, CANCELLED
  paidAt DateTime?
  sentAt DateTime?
  sentTo String? // Email address

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking  Booking @relation(fields: [bookingId], references: [id])
  customer User    @relation("CustomerInvoices", fields: [customerId], references: [id])
  worker   User    @relation("WorkerInvoices", fields: [workerId], references: [id])

  @@index([customerId])
  @@index([workerId], map: "Invoice_cleanerId_idx")
  @@index([invoiceNumber])
}

// ============================================
// GUARANTEE CLAIMS
// ============================================

model GuaranteeClaim {
  id String @id @default(cuid())

  // Relations
  bookingId  String
  customerId String
  workerId   String @map("cleanerId")

  // Claim details
  reason      GuaranteeClaimReason
  description String               @db.Text
  evidence    String[] // Array of file URLs (photos, etc.)

  // Status tracking
  status GuaranteeClaimStatus @default(PENDING)

  // Resolution
  resolution     GuaranteeResolution?
  resolutionNote String?              @db.Text
  refundAmount   Float?
  resolvedAt     DateTime?
  resolvedById   String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  booking    Booking @relation(fields: [bookingId], references: [id])
  customer   User    @relation("CustomerClaims", fields: [customerId], references: [id])
  worker     User    @relation("WorkerClaims", fields: [workerId], references: [id])
  resolvedBy User?   @relation("ResolvedClaims", fields: [resolvedById], references: [id])

  @@index([bookingId])
  @@index([customerId])
  @@index([workerId], map: "GuaranteeClaim_cleanerId_idx")
  @@index([status])
}

// ============================================
// SUBSCRIPTION MODEL
// ============================================

model Subscription {
  id     String @id @default(cuid())
  userId String @unique

  // Subscription details
  tier            SubscriptionTier   @default(FREE)
  status          SubscriptionStatus @default(ACTIVE)
  billingInterval BillingInterval? // null for FREE tier

  // Stripe subscription data
  stripeSubscriptionId     String?   @unique
  stripePriceId            String?
  stripeCurrentPeriodStart DateTime?
  stripeCurrentPeriodEnd   DateTime?

  // Trial info
  trialEndsAt DateTime?

  // Cancellation
  cancelAtPeriodEnd  Boolean   @default(false)
  canceledAt         DateTime?
  cancellationReason String?

  // Tier-specific benefits (cached for quick access)
  platformFeePercent  Float @default(15) // Standard is 15%, Pro is 10%
  prioritySearchBoost Int   @default(0) // 0-100 boost in search ranking
  maxEmployees        Int   @default(1) // For business accounts

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices SubscriptionInvoice[]

  @@index([tier])
  @@index([status])
  @@index([stripeSubscriptionId])
}

// ============================================
// DEMAND TRACKING SYSTEM
// ============================================

// Tracks all demand signals from customers searching for services
model DemandSignal {
  id String @id @default(cuid())

  // What was searched for
  professionId String?
  profession   Profession? @relation(fields: [professionId], references: [id], onDelete: SetNull)
  searchQuery  String? // Free-text search if profession not matched

  // Where
  city       String?
  state      String?
  country    String?
  postalCode String?
  latitude   Float?
  longitude  Float?

  // When
  requestedDate DateTime? // Specific date customer wanted service
  requestedTime String? // Preferred time

  // Signal type
  signalType DemandSignalType

  // Customer info (optional - may be anonymous search)
  customerId String?
  customer   User?   @relation("CustomerDemandSignals", fields: [customerId], references: [id], onDelete: SetNull)

  // Result
  wasMatched     Boolean   @default(false) // Did we find a worker?
  matchedAt      DateTime?
  workerId       String?   @map("cleanerId") // Worker who fulfilled the demand
  bookingCreated Boolean   @default(false) // Did it result in a booking?

  // Waitlist
  joinedWaitlist    Boolean   @default(false)
  waitlistNotified  Boolean   @default(false) // Customer notified when worker became available
  waitlistNotifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([professionId])
  @@index([city])
  @@index([country])
  @@index([signalType])
  @@index([wasMatched])
  @@index([createdAt])
}

enum DemandSignalType {
  SEARCH // Customer searched for service
  BOOKING_ATTEMPT // Customer tried to book but no availability
  WAITLIST // Customer explicitly joined waitlist
  UNFULFILLED // Customer had booking request with no workers available
  INQUIRY // Customer asked about a service
}

// Industry statistics for showing potential earnings
model IndustryStats {
  id String @id @default(cuid())

  professionId String
  profession   Profession @relation(fields: [professionId], references: [id], onDelete: Cascade)

  // Location (can be at different granularities)
  city    String?
  state   String?
  country String

  // Earnings data (actual platform data when available, otherwise industry estimates)
  source              IndustryStatsSource @default(ESTIMATED)
  avgHourlyRate       Float // Average hourly rate
  minHourlyRate       Float? // Minimum observed
  maxHourlyRate       Float? // Maximum observed
  avgMonthlyEarnings  Float? // Average monthly earnings (full-time equivalent)
  avgWeeklyBookings   Float? // Average bookings per week
  avgBookingValue     Float? // Average booking value

  // Market data
  totalWorkers        Int   @default(0) // Number of workers in this area
  totalCustomers      Int   @default(0) // Number of customers searching
  demandScore         Float @default(0) // 0-100 demand score
  supplyScore         Float @default(0) // 0-100 supply score (competition)
  opportunityScore    Float @default(0) // Calculated: demand - supply (higher = better opportunity)

  // Time periods
  periodStart DateTime
  periodEnd   DateTime

  // Metadata
  sampleSize Int      @default(0) // Number of data points used
  confidence Float    @default(0) // 0-1 confidence score
  lastUpdated DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([professionId, city, state, country, periodStart])
  @@index([professionId])
  @@index([country])
  @@index([city])
  @@index([opportunityScore])
}

enum IndustryStatsSource {
  PLATFORM // From actual Servantana data
  ESTIMATED // From industry research/estimates
  HYBRID // Combination of both
}

// ============================================
// SUBSCRIPTION INVOICE MODEL (for record keeping)
// ============================================

model SubscriptionInvoice {
  id             String @id @default(cuid())
  subscriptionId String
  userId         String

  // Stripe invoice data
  stripeInvoiceId       String  @unique
  stripePaymentIntentId String?

  // Amount
  amountDue  Float
  amountPaid Float
  currency   String @default("EUR")

  // Status
  status String // draft, open, paid, void, uncollectible
  paid   Boolean @default(false)

  // Period
  periodStart DateTime
  periodEnd   DateTime

  // URLs
  hostedInvoiceUrl String? // Stripe hosted invoice page
  invoicePdf       String? // PDF download URL

  // Timestamps
  createdAt DateTime  @default(now())
  paidAt    DateTime?

  // Relations
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([userId])
  @@index([stripeInvoiceId])
}

// ============================================
// COMPREHENSIVE ANALYTICS SYSTEM
// ============================================

// Track every user event/action for analytics
model UserEvent {
  id String @id @default(cuid())

  // Who
  userId    String?
  sessionId String? // For anonymous users

  // What happened
  eventType     UserEventType
  eventCategory EventCategory
  eventAction   String // Specific action: "click", "view", "submit", etc.
  eventLabel    String? // Additional context: button name, page section, etc.
  eventValue    Float? // Numeric value if applicable

  // Where it happened
  pageUrl      String?
  pageTitle    String?
  pagePath     String?
  referrerUrl  String?
  componentId  String? // Specific UI component

  // Context
  targetId     String? // ID of target entity (worker, booking, etc.)
  targetType   String? // Type: "worker", "booking", "service", etc.
  searchQuery  String? // If search-related
  searchFilters Json? // Filters applied

  // Device & Technical
  ipAddress    String?
  ipCity       String?
  ipRegion     String?
  ipCountry    String?
  ipIsp        String?
  ipType       String? // residential, vpn, datacenter
  userAgent    String?
  deviceType   String? // mobile, desktop, tablet
  deviceModel  String?
  browser      String?
  browserVersion String?
  os           String?
  osVersion    String?
  screenWidth  Int?
  screenHeight Int?
  timezone     String?
  language     String?

  // Session context
  sessionStartedAt DateTime?
  pageLoadTime     Int? // milliseconds
  timeOnPage       Int? // seconds
  scrollDepth      Int? // percentage 0-100

  // Funnel tracking
  funnelId   String? // Which funnel this event belongs to
  funnelStep Int? // Step number in funnel

  // UTM / Attribution
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?

  createdAt DateTime @default(now())

  // Relations
  user User? @relation("UserEvents", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([sessionId])
  @@index([eventType])
  @@index([eventCategory])
  @@index([createdAt])
  @@index([pageUrl])
  @@index([ipCountry])
}

enum UserEventType {
  PAGE_VIEW
  CLICK
  SEARCH
  FILTER
  SCROLL
  FORM_START
  FORM_FIELD
  FORM_SUBMIT
  FORM_ERROR
  FORM_ABANDON
  BOOKING_START
  BOOKING_STEP
  BOOKING_COMPLETE
  BOOKING_ABANDON
  BOOKING_CANCEL
  PAYMENT_START
  PAYMENT_SUCCESS
  PAYMENT_FAILURE
  LOGIN
  LOGOUT
  SIGNUP
  PROFILE_VIEW
  PROFILE_EDIT
  WORKER_VIEW
  MESSAGE_SEND
  MESSAGE_READ
  REVIEW_SUBMIT
  NOTIFICATION_VIEW
  NOTIFICATION_CLICK
  FEATURE_USE
  ERROR
  CUSTOM
}

enum EventCategory {
  NAVIGATION
  ENGAGEMENT
  CONVERSION
  ACQUISITION
  RETENTION
  REVENUE
  ERROR
  SYSTEM
}

// Aggregated user analytics (computed daily)
model UserAnalytics {
  id String @id @default(cuid())

  userId String
  date   DateTime // Date this snapshot represents

  // Engagement metrics
  sessionsCount      Int @default(0)
  totalSessionTime   Int @default(0) // seconds
  avgSessionDuration Int @default(0) // seconds
  pagesViewed        Int @default(0)
  eventsTriggered    Int @default(0)

  // Search behavior (customers)
  searchesCount        Int @default(0)
  searchesToBooking    Int @default(0) // searches that led to booking
  profilesViewed       Int @default(0)
  avgTimeOnProfile     Int @default(0) // seconds
  filtersUsed          Json? // Which filters used most

  // Booking behavior
  bookingsCreated    Int   @default(0)
  bookingsCompleted  Int   @default(0)
  bookingsCancelled  Int   @default(0)
  totalBookingValue  Float @default(0)
  avgBookingValue    Float @default(0)
  repeatBookings     Int   @default(0) // Same worker
  tipsGiven          Float @default(0)

  // Worker-specific
  bookingsReceived     Int   @default(0)
  bookingsAccepted     Int   @default(0)
  bookingsRejected     Int   @default(0)
  avgResponseTime      Int   @default(0) // minutes
  earningsTotal        Float @default(0)
  ratingsReceived      Int   @default(0)
  avgRatingReceived    Float @default(0)

  // Communication
  messagesSent     Int @default(0)
  messagesReceived Int @default(0)
  avgReplyTime     Int @default(0) // minutes

  // Reviews
  reviewsGiven       Int   @default(0)
  avgRatingGiven     Float @default(0)
  reviewsReceived    Int   @default(0)

  // Retention signals
  daysSinceLastVisit  Int @default(0)
  daysSinceLastBooking Int @default(0)
  isChurnRisk         Boolean @default(false)
  churnRiskScore      Float   @default(0) // 0-1

  // Lifetime metrics (cumulative)
  lifetimeBookings     Int   @default(0)
  lifetimeSpent        Float @default(0) // Customers
  lifetimeEarned       Float @default(0) // Workers
  lifetimeValue        Float @default(0) // LTV calculation
  accountAgeDays       Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation("UserAnalyticsRecords", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@index([isChurnRisk])
}

// Platform-wide metrics (computed daily)
model PlatformMetrics {
  id String @id @default(cuid())

  date        DateTime @unique // Date this snapshot represents
  periodType  MetricPeriod @default(DAILY)

  // User metrics
  totalUsers          Int @default(0)
  totalCustomers      Int @default(0)
  totalWorkers        Int @default(0)
  newUsersToday       Int @default(0)
  newCustomersToday   Int @default(0)
  newWorkersToday     Int @default(0)
  activeUsersToday    Int @default(0) // DAU
  activeUsersWeek     Int @default(0) // WAU
  activeUsersMonth    Int @default(0) // MAU

  // Engagement metrics
  totalSessions       Int @default(0)
  avgSessionDuration  Int @default(0) // seconds
  totalPageViews      Int @default(0)
  bounceRate          Float @default(0) // percentage

  // Search & Discovery
  totalSearches           Int @default(0)
  searchesWithResults     Int @default(0)
  searchesWithoutResults  Int @default(0)
  avgSearchResultsCount   Float @default(0)
  searchToBookingRate     Float @default(0)
  profileViewsTotal       Int @default(0)
  profileToBookingRate    Float @default(0)

  // Booking metrics
  bookingsCreated     Int   @default(0)
  bookingsConfirmed   Int   @default(0)
  bookingsCompleted   Int   @default(0)
  bookingsCancelled   Int   @default(0)
  bookingsCancelledByCustomer Int @default(0)
  bookingsCancelledByWorker   Int @default(0)
  avgBookingValue     Float @default(0)
  totalBookingValue   Float @default(0)

  // Revenue metrics
  totalRevenue        Float @default(0) // Platform fees
  customerFees        Float @default(0)
  workerFees          Float @default(0)
  tipsTotal           Float @default(0)
  refundsTotal        Float @default(0)
  chargebacksTotal    Float @default(0)
  avgRevenuePerUser   Float @default(0) // ARPU

  // Conversion funnels
  signupStarted       Int   @default(0)
  signupCompleted     Int   @default(0)
  signupConversionRate Float @default(0)
  firstBookingRate    Float @default(0) // % of new users who book
  repeatBookingRate   Float @default(0) // % of users who book again

  // Quality metrics
  avgWorkerRating     Float @default(0)
  avgCustomerRating   Float @default(0)
  disputesOpened      Int   @default(0)
  disputesResolved    Int   @default(0)
  avgDisputeResolutionTime Int @default(0) // hours
  guaranteeClaimsOpened    Int @default(0)
  guaranteeClaimsPaid      Float @default(0)

  // Supply/Demand
  totalDemandSignals      Int   @default(0)
  unmatchedDemand         Int   @default(0)
  waitlistCount           Int   @default(0)
  supplyDemandRatio       Float @default(0)
  avgWorkerUtilization    Float @default(0) // % of available slots booked

  // Retention
  day1Retention       Float @default(0) // % returning next day
  day7Retention       Float @default(0)
  day30Retention      Float @default(0)
  churnRate           Float @default(0)
  reactivationRate    Float @default(0)

  // Geographic
  topCitiesByBookings   Json? // [{city, count}]
  topCitiesByRevenue    Json?
  topCitiesByDemand     Json?
  supplyGapsByCity      Json? // [{city, demandCount, workerCount, gap}]

  // Service breakdown
  bookingsByService     Json? // [{service, count, revenue}]
  topProfessions        Json?

  createdAt DateTime @default(now())

  @@index([date])
  @@index([periodType])
}

enum MetricPeriod {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

// Fraud detection signals
model FraudSignal {
  id String @id @default(cuid())

  // Who/What
  userId      String?
  ipAddress   String?
  deviceId    String?
  bookingId   String?
  paymentId   String?
  reviewId    String?

  // Signal details
  signalType    FraudSignalType
  severity      FraudSeverity
  riskScore     Float // 0-100
  description   String
  details       Json? // Additional context

  // Detection context
  detectedBy    String // "system", "ai", "manual", "rule:xyz"
  ruleTriggered String? // Which rule was triggered

  // Status
  status        FraudSignalStatus @default(OPEN)
  reviewedById  String?
  reviewedAt    DateTime?
  resolution    String? // What action was taken
  falsePositive Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation("FraudSignals", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([ipAddress])
  @@index([signalType])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

enum FraudSignalType {
  MULTIPLE_ACCOUNTS
  SUSPICIOUS_IP
  VPN_DETECTED
  VELOCITY_ABUSE // Too many actions too fast
  FAKE_REVIEW
  REVIEW_MANIPULATION
  PAYMENT_FRAUD
  CHARGEBACK
  IDENTITY_MISMATCH
  LOCATION_SPOOFING
  BOT_BEHAVIOR
  ACCOUNT_TAKEOVER
  FAKE_PROFILE
  SPAM_MESSAGES
  POLICY_VIOLATION
  CUSTOM
}

enum FraudSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FraudSignalStatus {
  OPEN
  INVESTIGATING
  CONFIRMED
  DISMISSED
  RESOLVED
}

// User acquisition tracking
model UserAcquisition {
  id String @id @default(cuid())

  userId String @unique

  // First touch attribution
  firstReferrer     String?
  firstLandingPage  String?
  firstUtmSource    String?
  firstUtmMedium    String?
  firstUtmCampaign  String?
  firstUtmTerm      String?
  firstUtmContent   String?

  // Referral
  referralCode      String?
  referredByUserId  String?

  // Device/location at signup
  signupIp          String?
  signupCountry     String?
  signupCity        String?
  signupDevice      String?
  signupBrowser     String?
  signupOs          String?

  // Conversion tracking
  signupStartedAt   DateTime?
  signupCompletedAt DateTime?
  firstBookingAt    DateTime?
  firstPaymentAt    DateTime?

  // Campaign tracking
  campaignId        String?
  adId              String?
  affiliateId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

