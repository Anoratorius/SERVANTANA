// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// Enums for PostgreSQL
// Note: CLEANER is deprecated, use WORKER instead. Keeping for backward compatibility.
enum Role {
  CUSTOMER
  WORKER
  CLEANER // @deprecated - use WORKER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EtaStatus {
  ON_THE_WAY
  ARRIVED
  STARTED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum EarningStatus {
  PENDING
  AVAILABLE
  PAID_OUT
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ============================================
// DISPUTE SYSTEM ENUMS
// ============================================

enum DisputeStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

enum DisputeType {
  SERVICE_QUALITY
  PAYMENT_ISSUE
  NO_SHOW
  PROPERTY_DAMAGE
  UNPROFESSIONAL_BEHAVIOR
  OTHER
}

enum DisputeResolution {
  FULL_REFUND
  PARTIAL_REFUND
  NO_REFUND
  SERVICE_CREDIT
  DISMISSED
}

// ============================================
// GUARANTEE CLAIM ENUMS
// ============================================

enum GuaranteeClaimStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  DENIED
  RESOLVED
}

enum GuaranteeClaimReason {
  NO_SHOW
  INCOMPLETE_SERVICE
  POOR_QUALITY
  PROPERTY_DAMAGE
  LATE_ARRIVAL
  UNPROFESSIONAL
  OTHER
}

enum GuaranteeResolution {
  FULL_REFUND
  PARTIAL_REFUND
  FREE_REBOOKING
  SERVICE_CREDIT
  DENIED
}

// ============================================
// NOTIFICATION ENUMS
// ============================================

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  BOOKING_COMPLETED
  BOOKING_ETA_UPDATE
  PAYMENT_RECEIVED
  PAYOUT_SENT
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  DOCUMENT_VERIFIED
  DOCUMENT_REJECTED
  MESSAGE_RECEIVED
  REVIEW_RECEIVED
  ADMIN_EMAIL
  ADMIN_ANNOUNCEMENT
}

// ============================================
// BOOKING CHANGE ENUMS
// ============================================

enum BookingChangeType {
  RESCHEDULE
  CANCEL
}

enum BookingChangeStatus {
  PENDING
  APPROVED
  REJECTED
  AUTO_APPROVED
}

// ============================================
// DOCUMENT VERIFICATION ENUMS
// ============================================

enum DocumentType {
  GOVERNMENT_ID
  DRIVERS_LICENSE
  PASSPORT
  BUSINESS_LICENSE
  INSURANCE_CERTIFICATE
  BACKGROUND_CHECK
  OTHER
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum CategoryStatus {
  PENDING
  APPROVED
  REJECTED
}

// User model - base for both customers and workers
model User {
  id                String     @id @default(cuid())
  internalId        String?    @unique // 9-digit internal ID (admin-only visible)
  email             String     @unique
  emailVerified     DateTime?
  phone             String?    @unique
  phoneVerified     DateTime?
  password          String?
  firstName         String
  lastName          String
  avatar            String?
  role              Role       @default(CUSTOMER)
  status            UserStatus @default(ACTIVE)
  suspendedUntil    DateTime? // For temporary suspensions
  suspendedReason   String? // Reason for suspension/ban
  preferredLanguage String     @default("en")
  tokenVersion      Int        @default(0) // Incremented on password change to invalidate sessions

  // Location verification (required for all users)
  latitude           Float? // Verified location
  longitude          Float?
  locationCity       String? // Reverse geocoded city
  locationCountry    String? // Reverse geocoded country
  locationVerifiedAt DateTime? // When location was verified
  lastKnownIp        String? // Last known IP for fraud detection

  // Stripe Customer ID (for customers to save payment methods)
  stripeCustomerId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  workerProfile      WorkerProfile?
  accounts           Account[]
  sessions           Session[]
  bookingsAsCustomer Booking[]      @relation("CustomerBookings")
  bookingsAsWorker   Booking[]      @relation("WorkerBookings")
  reviewsGiven       Review[]       @relation("ReviewsGiven")
  reviewsReceived    Review[]       @relation("ReviewsReceived")
  messagesSent       Message[]      @relation("MessagesSent")
  messagesReceived   Message[]      @relation("MessagesReceived")
  favoriteWorkers    Favorite[]     @relation("CustomerFavorites")
  favoritedBy        Favorite[]     @relation("WorkerFavorites")
  earnings           Earning[]      @relation("WorkerEarnings")
  payouts            Payout[]       @relation("WorkerPayouts")

  // Security relations
  userSessions       UserSession[]            @relation("UserSessions")
  userDevices        UserDevice[]             @relation("UserDevices")
  emailVerifications EmailVerificationToken[] @relation("EmailVerifications")

  // Dispute relations
  disputesAsCustomer Dispute[]         @relation("CustomerDisputes")
  disputesAsWorker   Dispute[]         @relation("WorkerDisputes")
  disputesResolved   Dispute[]         @relation("ResolvedDisputes")
  disputeMessages    DisputeMessage[]  @relation("DisputeMessagesSent")
  disputeEvidence    DisputeEvidence[] @relation("DisputeEvidenceUploaded")

  // Notification relations
  notificationPreferences NotificationPreference[] @relation("NotificationPreferences")
  pushSubscriptions       PushSubscription[]       @relation("PushSubscriptions")
  mobileDeviceTokens      MobileDeviceToken[]      @relation("MobileDeviceTokens")
  notificationLogs        NotificationLog[]        @relation("NotificationLogs")
  reminderPreference      ReminderPreference?      @relation("ReminderPreferences")
  bookingReminders        BookingReminder[]        @relation("BookingReminders")

  // Booking change relations
  bookingChangeRequests  BookingChange[] @relation("BookingChangeRequester")
  bookingChangeResponses BookingChange[] @relation("BookingChangeResponder")

  // Photo relations
  bookingPhotos BookingPhoto[] @relation("BookingPhotosUploaded")

  // Document relations
  workerDocuments   WorkerDocument[] @relation("WorkerDocuments")
  documentsVerified WorkerDocument[] @relation("DocumentsVerified")

  // Calendar relations
  calendarConnections CalendarConnection[] @relation("CalendarConnections")

  // Analytics relations
  analyticsSnapshots AnalyticsSnapshot[] @relation("AnalyticsSnapshots")

  // Property relations
  properties Property[] @relation("UserProperties")

  // Team booking relations
  teamBookings BookingTeamMember[] @relation("TeamMemberBookings")

  // Invoice relations
  invoicesAsCustomer Invoice[] @relation("CustomerInvoices")
  invoicesAsWorker   Invoice[] @relation("WorkerInvoices")

  // Customer review relations (workers rating customers)
  customerReviewsGiven    CustomerReview[] @relation("CustomerReviewsGiven")
  customerReviewsReceived CustomerReview[] @relation("CustomerReviewsReceived")

  // Guarantee claim relations
  guaranteeClaimsAsCustomer GuaranteeClaim[] @relation("CustomerClaims")
  guaranteeClaimsAsWorker   GuaranteeClaim[] @relation("WorkerClaims")
  guaranteeClaimsResolved   GuaranteeClaim[] @relation("ResolvedClaims")

  // Subscription relations
  subscription         Subscription?
  subscriptionInvoices SubscriptionInvoice[]

  // Demand tracking relations
  demandSignals DemandSignal[] @relation("CustomerDemandSignals")

  // Analytics relations
  userEvents          UserEvent[]       @relation("UserEvents")
  userAnalytics       UserAnalytics[]   @relation("UserAnalyticsRecords")
  fraudSignals        FraudSignal[]     @relation("FraudSignals")
  acquisitionRecord   UserAcquisition?  @relation("UserAcquisitionRecord")
}

// NextAuth.js Account model
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// NextAuth.js Session model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NextAuth.js VerificationToken model
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Password reset token for email/phone verification
model PasswordResetToken {
  id         String   @id @default(cuid())
  identifier String // email or phone number
  token      String // 6-digit code
  type       String // "email" or "phone"
  expires    DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@index([identifier])
}

// Worker profile - additional info for workers
model WorkerProfile {
  id                 String  @id @default(cuid())
  userId             String  @unique
  bio                String?
  introVideoUrl      String? // Short intro video URL
  introVideoId       String? // Cloudinary public ID for deletion
  hourlyRate         Float
  currency           String  @default("USD")
  experienceYears    Int     @default(0)
  verified           Boolean @default(false)
  isActive           Boolean @default(true) // Admin can deactivate without deleting
  onboardingComplete Boolean @default(false) // Profile only visible after onboarding
  availableNow       Boolean @default(false)
  ecoFriendly        Boolean @default(false)
  petFriendly        Boolean @default(false)

  // Worker subscription (12 units/year after first job)
  workerSubscriptionStatus WorkerSubscriptionStatus @default(NONE)
  subscriptionExpiresAt    DateTime? // When current subscription expires
  firstJobCompletedAt      DateTime? // When worker completed their first job
  paymentDueAt             DateTime? // 24h deadline to pay after first job
  isVisible                Boolean                  @default(true) // False if suspended for non-payment

  // Service area
  address       String?
  city          String?
  state         String?
  country       String?
  postalCode    String?
  latitude      Float?
  longitude     Float?
  serviceRadius Int     @default(10) // in km
  timezone      String  @default("Europe/Berlin") // IANA timezone for payout timing

  // Payment
  paypalEmail   String? // PayPal email for receiving payouts
  iban          String? // IBAN for bank transfers
  accountHolder String? // Bank account holder name
  cryptoWallets CryptoWallet[]

  // Stripe Connect
  stripeAccountId          String? @unique // Stripe Connect Express account ID
  stripeOnboardingComplete Boolean @default(false)

  // Stats
  totalBookings Int   @default(0)
  averageRating Float @default(0)
  responseTime  Int? // in minutes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  services     WorkerService[]
  availability Availability[]
  professions  WorkerProfession[]

  @@map("CleanerProfile")
}

// Crypto wallet for workers
model CryptoWallet {
  id              String   @id @default(cuid())
  workerProfileId String   @map("cleanerProfileId")
  currency        String // BTC, ETH, LTC
  address         String // Public wallet address
  derivationIndex Int // HD wallet derivation index
  balance         Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)

  @@unique([workerProfileId, currency])
  @@index([workerProfileId])
}

// Service types offered
model Service {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "regular", "deep", "moveInOut"
  description String?
  basePrice   Float
  duration    Int // estimated duration in minutes
  category    String   @default("cleaning")
  icon        String?
  isActive    Boolean  @default(true)
  isSpecialty Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  workerServices WorkerService[]
  bookings       Booking[]
}

// Junction table: which services a worker offers with their custom prices
model WorkerService {
  id          String   @id @default(cuid())
  workerId    String   @map("cleanerId")
  serviceId   String
  customPrice Float? // null means use base price
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  worker  WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  service Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([workerId, serviceId])
  @@map("CleanerService")
}

// Worker availability schedule
model Availability {
  id        String  @id @default(cuid())
  workerId  String  @map("cleanerId")
  dayOfWeek Int // 0 = Sunday, 6 = Saturday
  startTime String // "09:00"
  endTime   String // "17:00"
  isActive  Boolean @default(true)

  worker WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workerId, dayOfWeek])
}

// Booking model
model Booking {
  id         String  @id @default(cuid())
  customerId String
  workerId   String  @map("cleanerId")
  serviceId  String?
  propertyId String? // Optional link to saved property

  // Scheduling
  scheduledDate DateTime
  scheduledTime String // "14:00"
  duration      Int // in minutes

  // Location
  address    String?
  city       String?
  state      String?
  postalCode String?
  latitude   Float?
  longitude  Float?

  // Details
  notes      String?
  status     BookingStatus @default(PENDING)
  totalPrice Float
  currency   String        @default("USD")
  teamSize   Int           @default(1) // Number of workers for this job

  // Tipping
  tipAmount Float? // Tip amount (100% goes to worker)
  tipPaidAt DateTime?

  // Timestamps
  confirmedAt        DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  cancelledByWorker  Boolean   @default(false) @map("cancelledByCleaner")

  // Substitution tracking
  substitutedFromId String? // Original booking this was created from
  substitutedToId   String? // New booking created as substitute

  // GPS tracking (worker en route)
  trackingActive     Boolean    @default(false)
  workerLatitude     Float?     @map("cleanerLatitude")
  workerLongitude    Float?     @map("cleanerLongitude")
  lastLocationUpdate DateTime?
  estimatedArrival   DateTime?
  etaStatus          EtaStatus?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  customer        User                @relation("CustomerBookings", fields: [customerId], references: [id])
  worker          User                @relation("WorkerBookings", fields: [workerId], references: [id])
  service         Service?            @relation(fields: [serviceId], references: [id])
  property        Property?           @relation(fields: [propertyId], references: [id])
  review          Review?
  messages        Message[]
  payment         Payment?
  earning         Earning?
  disputes        Dispute[]
  changes         BookingChange[]
  photos          BookingPhoto[]
  calendarEvents  CalendarEvent[]
  reminders       BookingReminder[]   @relation("BookingReminders")
  teamMembers     BookingTeamMember[]
  invoice         Invoice?
  customerReview  CustomerReview?
  guaranteeClaims GuaranteeClaim[]

  @@index([customerId])
  @@index([propertyId])
  @@index([workerId], map: "Booking_cleanerId_idx")
  @@index([status])
  @@index([scheduledDate])
}

// Review model
model Review {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  reviewerId String // customer who left the review
  revieweeId String // worker who received the review
  rating     Int // 1-5
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewer User    @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee User    @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@index([revieweeId])
  @@index([reviewerId])
}

// Customer Review model (worker rates customer)
model CustomerReview {
  id         String @id @default(cuid())
  bookingId  String @unique
  workerId   String @map("cleanerId") // Worker who left the review
  customerId String // Customer being reviewed

  // Ratings (1-5 scale)
  punctuality   Int // Was customer on time / property accessible
  cleanliness   Int // Initial state of property
  communication Int // How well did customer communicate
  overall       Int // Overall experience

  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  worker   User    @relation("CustomerReviewsGiven", fields: [workerId], references: [id])
  customer User    @relation("CustomerReviewsReceived", fields: [customerId], references: [id])

  @@index([customerId])
  @@index([workerId], map: "CustomerReview_cleanerId_idx")
}

// Message model for customer-worker communication
model Message {
  id         String    @id @default(cuid())
  senderId   String
  receiverId String
  bookingId  String?
  content    String
  read       Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  // Relations
  sender   User     @relation("MessagesSent", fields: [senderId], references: [id])
  receiver User     @relation("MessagesReceived", fields: [receiverId], references: [id])
  booking  Booking? @relation(fields: [bookingId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

// Favorite workers
model Favorite {
  id         String   @id @default(cuid())
  customerId String
  workerId   String   @map("cleanerId")
  createdAt  DateTime @default(now())

  customer User @relation("CustomerFavorites", fields: [customerId], references: [id], onDelete: Cascade)
  worker   User @relation("WorkerFavorites", fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([customerId, workerId], map: "Favorite_customerId_cleanerId_key")
}

// Payment model for tracking payments (Stripe, PayPal, and Crypto)
model Payment {
  id               String        @id @default(cuid())
  bookingId        String        @unique
  provider         String        @default("stripe") // stripe, paypal, crypto
  stripePaymentId  String?       @unique // Stripe PaymentIntent ID
  stripeSessionId  String?       @unique // Stripe Checkout Session ID
  paypalOrderId    String?       @unique // PayPal Order ID
  paypalCaptureId  String? // PayPal Capture ID
  cryptoChargeId   String?       @unique // Coinbase Commerce Charge ID
  cryptoChargeCode String? // Coinbase Commerce Charge Code
  cryptoNetwork    String? // bitcoin, ethereum, litecoin
  cryptoTxId       String? // Blockchain transaction ID
  amount           Float // Total amount charged to customer
  currency         String        @default("EUR")
  status           PaymentStatus @default(PENDING)
  paymentMethod    String? // card, bank_transfer, paypal, crypto, etc.

  // Fee breakdown
  bookingAmount  Float? // Original booking price (worker's rate)
  customerFee    Float? // Fixed + percentage fee from customer
  workerFee      Float?    @map("cleanerFee") // Fixed + percentage fee from worker
  platformFee    Float? // Total platform fee (customerFee + workerFee)
  workerPayout   Float?    @map("cleanerPayout") // Amount transferred to worker
  receiptUrl     String?
  failureReason  String?
  refundedAmount Float?
  refundedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

// Earnings model for tracking worker earnings
model Earning {
  id          String        @id @default(cuid())
  workerId    String        @map("cleanerId")
  bookingId   String        @unique
  amount      Float // Amount earned (after platform fee)
  platformFee Float // Platform's cut
  grossAmount Float // Total payment received
  currency    String        @default("USD")
  status      EarningStatus @default(PENDING)
  availableAt DateTime // When funds become available for payout
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  worker   User    @relation("WorkerEarnings", fields: [workerId], references: [id])
  booking  Booking @relation(fields: [bookingId], references: [id])
  payout   Payout? @relation(fields: [payoutId], references: [id])
  payoutId String?

  @@index([workerId], map: "Earning_cleanerId_idx")
  @@index([status])
}

// Custom category submitted by users
model Category {
  id          String         @id @default(cuid())
  name        String
  nameDE      String? // German translation
  description String?
  emoji       String         @default("📁")
  gradient    String         @default("from-gray-400 to-gray-600")
  status      CategoryStatus @default(PENDING)
  submittedBy String? // userId of submitter
  reviewedBy  String? // admin userId who reviewed
  reviewedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  professions Profession[]

  @@index([status])
}

// Professions within a category (what workers do)
model Profession {
  id          String         @id @default(cuid())
  categoryId  String? // Optional - can be assigned later by admin
  name        String         @unique
  nameDE      String? // German translation
  emoji       String         @default("👤")
  status      CategoryStatus @default(PENDING) // PENDING until admin approves
  submittedBy String? // userId of worker who suggested it
  reviewedBy  String? // admin who approved/rejected
  reviewedAt  DateTime?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  category Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  workers  WorkerProfession[]

  // Demand tracking relations
  demandSignals DemandSignal[]
  industryStats IndustryStats[]

  @@index([categoryId])
  @@index([status])
}

// Junction table: Workers can have multiple professions
model WorkerProfession {
  id           String   @id @default(cuid())
  workerId     String   @map("cleanerId")
  professionId String
  isPrimary    Boolean  @default(false) // Main profession shown first
  hourlyRate   Float? // Rate for this specific profession (nullable for backwards compatibility)
  createdAt    DateTime @default(now())

  worker     WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  profession Profession    @relation(fields: [professionId], references: [id], onDelete: Cascade)

  @@unique([workerId, professionId])
  @@index([workerId])
  @@index([professionId])
  @@map("CleanerProfession")
}

// Payout model for tracking worker payouts
model Payout {
  id             String       @id @default(cuid())
  workerId       String       @map("cleanerId")
  amount         Float
  currency       String       @default("USD")
  status         PayoutStatus @default(PENDING)
  payoutMethod   String? // bank_transfer, paypal, etc.
  stripePayoutId String?      @unique
  failureReason  String?
  processedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  worker   User      @relation("WorkerPayouts", fields: [workerId], references: [id])
  earnings Earning[]

  @@index([workerId], map: "Payout_cleanerId_idx")
  @@index([status])
}

// ============================================
// DISPUTE SYSTEM MODELS
// ============================================

model Dispute {
  id             String             @id @default(cuid())
  bookingId      String
  customerId     String
  workerId       String             @map("cleanerId")
  type           DisputeType
  status         DisputeStatus      @default(OPEN)
  subject        String
  description    String
  resolution     DisputeResolution?
  resolutionNote String?
  refundAmount   Float?
  resolvedById   String?
  resolvedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  booking    Booking           @relation(fields: [bookingId], references: [id])
  customer   User              @relation("CustomerDisputes", fields: [customerId], references: [id])
  worker     User              @relation("WorkerDisputes", fields: [workerId], references: [id])
  resolvedBy User?             @relation("ResolvedDisputes", fields: [resolvedById], references: [id])
  messages   DisputeMessage[]
  evidence   DisputeEvidence[]

  @@index([customerId])
  @@index([workerId], map: "Dispute_cleanerId_idx")
  @@index([status])
  @@index([bookingId])
}

model DisputeMessage {
  id        String   @id @default(cuid())
  disputeId String
  senderId  String
  content   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  dispute Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  sender  User    @relation("DisputeMessagesSent", fields: [senderId], references: [id])

  @@index([disputeId])
}

model DisputeEvidence {
  id          String   @id @default(cuid())
  disputeId   String
  uploaderId  String
  fileUrl     String
  fileName    String
  fileType    String
  fileSize    Int
  description String?
  createdAt   DateTime @default(now())

  dispute  Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  uploader User    @relation("DisputeEvidenceUploaded", fields: [uploaderId], references: [id])

  @@index([disputeId])
}

// ============================================
// NOTIFICATION MODELS
// ============================================

model NotificationPreference {
  id        String              @id @default(cuid())
  userId    String
  type      NotificationType
  channel   NotificationChannel
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

