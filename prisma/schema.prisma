// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// Enums for PostgreSQL
// Note: CLEANER is deprecated, use WORKER instead. Keeping for backward compatibility.
enum Role {
  CUSTOMER
  WORKER
  CLEANER // @deprecated - use WORKER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum EarningStatus {
  PENDING
  AVAILABLE
  PAID_OUT
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ============================================
// DISPUTE SYSTEM ENUMS
// ============================================

enum DisputeStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

enum DisputeType {
  SERVICE_QUALITY
  PAYMENT_ISSUE
  NO_SHOW
  PROPERTY_DAMAGE
  UNPROFESSIONAL_BEHAVIOR
  OTHER
}

enum DisputeResolution {
  FULL_REFUND
  PARTIAL_REFUND
  NO_REFUND
  SERVICE_CREDIT
  DISMISSED
}

// ============================================
// GUARANTEE CLAIM ENUMS
// ============================================

enum GuaranteeClaimStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  DENIED
  RESOLVED
}

enum GuaranteeClaimReason {
  NO_SHOW
  INCOMPLETE_SERVICE
  POOR_QUALITY
  PROPERTY_DAMAGE
  LATE_ARRIVAL
  UNPROFESSIONAL
  OTHER
}

enum GuaranteeResolution {
  FULL_REFUND
  PARTIAL_REFUND
  FREE_REBOOKING
  SERVICE_CREDIT
  DENIED
}

// ============================================
// NOTIFICATION ENUMS
// ============================================

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  BOOKING_COMPLETED
  PAYMENT_RECEIVED
  PAYOUT_SENT
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  DOCUMENT_VERIFIED
  DOCUMENT_REJECTED
  MESSAGE_RECEIVED
  REVIEW_RECEIVED
  ADMIN_EMAIL
  ADMIN_ANNOUNCEMENT
}

// ============================================
// BOOKING CHANGE ENUMS
// ============================================

enum BookingChangeType {
  RESCHEDULE
  CANCEL
}

enum BookingChangeStatus {
  PENDING
  APPROVED
  REJECTED
  AUTO_APPROVED
}

// ============================================
// DOCUMENT VERIFICATION ENUMS
// ============================================

enum DocumentType {
  GOVERNMENT_ID
  DRIVERS_LICENSE
  PASSPORT
  BUSINESS_LICENSE
  INSURANCE_CERTIFICATE
  BACKGROUND_CHECK
  OTHER
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum CategoryStatus {
  PENDING
  APPROVED
  REJECTED
}

// User model - base for both customers and cleaners
model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  phone             String?   @unique
  phoneVerified     DateTime?
  password          String?
  firstName         String
  lastName          String
  avatar            String?
  role              Role       @default(CUSTOMER)
  status            UserStatus @default(ACTIVE)
  suspendedUntil    DateTime?  // For temporary suspensions
  suspendedReason   String?    // Reason for suspension/ban
  preferredLanguage String     @default("en")
  tokenVersion      Int        @default(0) // Incremented on password change to invalidate sessions

  // Location verification (required for all users)
  latitude          Float?     // Verified location
  longitude         Float?
  locationCity      String?    // Reverse geocoded city
  locationCountry   String?    // Reverse geocoded country
  locationVerifiedAt DateTime? // When location was verified
  lastKnownIp       String?    // Last known IP for fraud detection

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  workerProfile    WorkerProfile?
  accounts         Account[]
  sessions         Session[]
  bookingsAsCustomer Booking[] @relation("CustomerBookings")
  bookingsAsCleaner  Booking[] @relation("CleanerBookings")
  reviewsGiven     Review[]  @relation("ReviewsGiven")
  reviewsReceived  Review[]  @relation("ReviewsReceived")
  messagesSent     Message[] @relation("MessagesSent")
  messagesReceived Message[] @relation("MessagesReceived")
  favoriteCleaners Favorite[] @relation("CustomerFavorites")
  favoritedBy      Favorite[] @relation("CleanerFavorites")
  earnings         Earning[]  @relation("CleanerEarnings")
  payouts          Payout[]   @relation("CleanerPayouts")

  // Security relations
  userSessions     UserSession[] @relation("UserSessions")
  userDevices      UserDevice[]  @relation("UserDevices")
  emailVerifications EmailVerificationToken[] @relation("EmailVerifications")

  // Dispute relations
  disputesAsCustomer Dispute[] @relation("CustomerDisputes")
  disputesAsCleaner  Dispute[] @relation("CleanerDisputes")
  disputesResolved   Dispute[] @relation("ResolvedDisputes")
  disputeMessages    DisputeMessage[] @relation("DisputeMessagesSent")
  disputeEvidence    DisputeEvidence[] @relation("DisputeEvidenceUploaded")

  // Notification relations
  notificationPreferences NotificationPreference[] @relation("NotificationPreferences")
  pushSubscriptions       PushSubscription[] @relation("PushSubscriptions")
  notificationLogs        NotificationLog[] @relation("NotificationLogs")
  reminderPreference      ReminderPreference? @relation("ReminderPreferences")
  bookingReminders        BookingReminder[] @relation("BookingReminders")

  // Booking change relations
  bookingChangeRequests  BookingChange[] @relation("BookingChangeRequester")
  bookingChangeResponses BookingChange[] @relation("BookingChangeResponder")

  // Photo relations
  bookingPhotos  BookingPhoto[] @relation("BookingPhotosUploaded")

  // Document relations
  cleanerDocuments  WorkerDocument[] @relation("CleanerDocuments")
  documentsVerified WorkerDocument[] @relation("DocumentsVerified")

  // Calendar relations
  calendarConnections CalendarConnection[] @relation("CalendarConnections")

  // Analytics relations
  analyticsSnapshots AnalyticsSnapshot[] @relation("AnalyticsSnapshots")

  // Property relations
  properties Property[] @relation("UserProperties")

  // Team booking relations
  teamBookings BookingTeamMember[] @relation("TeamMemberBookings")

  // Invoice relations
  invoicesAsCustomer Invoice[] @relation("CustomerInvoices")
  invoicesAsCleaner  Invoice[] @relation("CleanerInvoices")

  // Customer review relations (cleaners rating customers)
  customerReviewsGiven    CustomerReview[] @relation("CustomerReviewsGiven")
  customerReviewsReceived CustomerReview[] @relation("CustomerReviewsReceived")

  // Guarantee claim relations
  guaranteeClaimsAsCustomer GuaranteeClaim[] @relation("CustomerClaims")
  guaranteeClaimsAsCleaner  GuaranteeClaim[] @relation("CleanerClaims")
  guaranteeClaimsResolved   GuaranteeClaim[] @relation("ResolvedClaims")
}

// NextAuth.js Account model
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// NextAuth.js Session model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NextAuth.js VerificationToken model
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Password reset token for email/phone verification
model PasswordResetToken {
  id         String   @id @default(cuid())
  identifier String   // email or phone number
  token      String   // 6-digit code
  type       String   // "email" or "phone"
  expires    DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@index([identifier])
}

// Worker profile - additional info for workers
model WorkerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  bio             String?
  introVideoUrl   String?  // Short intro video URL
  introVideoId    String?  // Cloudinary public ID for deletion
  hourlyRate      Float
  currency        String   @default("USD")
  experienceYears Int      @default(0)
  verified        Boolean  @default(false)
  isActive        Boolean  @default(true)  // Admin can deactivate without deleting
  onboardingComplete Boolean @default(false) // Profile only visible after onboarding
  availableNow    Boolean  @default(false)
  ecoFriendly     Boolean  @default(false)
  petFriendly     Boolean  @default(false)

  // Service area
  address         String?
  city            String?
  state           String?
  country         String?
  postalCode      String?
  latitude        Float?
  longitude       Float?
  serviceRadius   Int      @default(10) // in km
  timezone        String   @default("Europe/Berlin") // IANA timezone for payout timing

  // Payment
  paypalEmail     String?  // PayPal email for receiving payouts
  iban            String?  // IBAN for bank transfers
  accountHolder   String?  // Bank account holder name
  cryptoWallets   CryptoWallet[]

  // Stripe Connect
  stripeAccountId         String?  @unique // Stripe Connect Express account ID
  stripeOnboardingComplete Boolean @default(false)

  // Stats
  totalBookings   Int      @default(0)
  averageRating   Float    @default(0)
  responseTime    Int?     // in minutes

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  services        WorkerService[]
  availability    Availability[]
  professions     WorkerProfession[]

  @@map("CleanerProfile")
}

// Crypto wallet for workers
model CryptoWallet {
  id               String   @id @default(cuid())
  workerProfileId  String   @map("cleanerProfileId")
  currency         String   // BTC, ETH, LTC
  address          String   // Public wallet address
  derivationIndex  Int      // HD wallet derivation index
  balance          Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workerProfile    WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)

  @@unique([workerProfileId, currency])
  @@index([workerProfileId])
}

// Service types offered
model Service {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "regular", "deep", "moveInOut"
  description String?
  basePrice   Float
  duration    Int      // estimated duration in minutes
  category    String   @default("cleaning")
  icon        String?
  isActive    Boolean  @default(true)
  isSpecialty Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  workerServices  WorkerService[]
  bookings        Booking[]
}

// Junction table: which services a worker offers with their custom prices
model WorkerService {
  id          String   @id @default(cuid())
  workerId    String   @map("cleanerId")
  serviceId   String
  customPrice Float?   // null means use base price
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  worker      WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  service     Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([workerId, serviceId])
  @@map("CleanerService")
}

// Worker availability schedule
model Availability {
  id        String   @id @default(cuid())
  workerId  String   @map("cleanerId")
  dayOfWeek Int      // 0 = Sunday, 6 = Saturday
  startTime String   // "09:00"
  endTime   String   // "17:00"
  isActive  Boolean  @default(true)

  worker    WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workerId, dayOfWeek])
}

// Booking model
model Booking {
  id            String   @id @default(cuid())
  customerId    String
  cleanerId     String
  serviceId     String?
  propertyId    String?  // Optional link to saved property

  // Scheduling
  scheduledDate DateTime
  scheduledTime String   // "14:00"
  duration      Int      // in minutes

  // Location
  address       String?
  city          String?
  state         String?
  postalCode    String?
  latitude      Float?
  longitude     Float?

  // Details
  notes         String?
  status        BookingStatus @default(PENDING)
  totalPrice    Float
  currency      String   @default("USD")
  teamSize      Int      @default(1)  // Number of cleaners for this job

  // Tipping
  tipAmount     Float?   // Tip amount (100% goes to cleaner)
  tipPaidAt     DateTime?

  // Timestamps
  confirmedAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?
  cancellationReason String?
  cancelledByCleaner Boolean @default(false)

  // Substitution tracking
  substitutedFromId String?  // Original booking this was created from
  substitutedToId   String?  // New booking created as substitute

  // GPS tracking (cleaner en route)
  trackingActive      Boolean   @default(false)
  cleanerLatitude     Float?
  cleanerLongitude    Float?
  lastLocationUpdate  DateTime?
  estimatedArrival    DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  customer      User     @relation("CustomerBookings", fields: [customerId], references: [id])
  cleaner       User     @relation("CleanerBookings", fields: [cleanerId], references: [id])
  service       Service?  @relation(fields: [serviceId], references: [id])
  property      Property? @relation(fields: [propertyId], references: [id])
  review        Review?
  messages      Message[]
  payment       Payment?
  earning       Earning?
  disputes      Dispute[]
  changes       BookingChange[]
  photos        BookingPhoto[]
  calendarEvents CalendarEvent[]
  reminders     BookingReminder[] @relation("BookingReminders")
  teamMembers   BookingTeamMember[]
  invoice       Invoice?
  customerReview CustomerReview?
  guaranteeClaims GuaranteeClaim[]

  @@index([customerId])
  @@index([propertyId])
  @@index([cleanerId])
  @@index([status])
  @@index([scheduledDate])
}

// Review model
model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique
  reviewerId String  // customer who left the review
  revieweeId String  // cleaner who received the review
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewer  User     @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee  User     @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@index([revieweeId])
  @@index([reviewerId])
}

// Customer Review model (cleaner rates customer)
model CustomerReview {
  id              String   @id @default(cuid())
  bookingId       String   @unique
  cleanerId       String   // Cleaner who left the review
  customerId      String   // Customer being reviewed

  // Ratings (1-5 scale)
  punctuality     Int      // Was customer on time / property accessible
  cleanliness     Int      // Initial state of property
  communication   Int      // How well did customer communicate
  overall         Int      // Overall experience

  comment         String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  cleaner         User     @relation("CustomerReviewsGiven", fields: [cleanerId], references: [id])
  customer        User     @relation("CustomerReviewsReceived", fields: [customerId], references: [id])

  @@index([customerId])
  @@index([cleanerId])
}

// Message model for customer-cleaner communication
model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  bookingId  String?
  content    String
  read       Boolean  @default(false)
  readAt     DateTime?
  createdAt  DateTime @default(now())

  // Relations
  sender     User     @relation("MessagesSent", fields: [senderId], references: [id])
  receiver   User     @relation("MessagesReceived", fields: [receiverId], references: [id])
  booking    Booking? @relation(fields: [bookingId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

// Favorite cleaners
model Favorite {
  id         String   @id @default(cuid())
  customerId String
  cleanerId  String
  createdAt  DateTime @default(now())

  customer   User     @relation("CustomerFavorites", fields: [customerId], references: [id], onDelete: Cascade)
  cleaner    User     @relation("CleanerFavorites", fields: [cleanerId], references: [id], onDelete: Cascade)

  @@unique([customerId, cleanerId])
}

// Payment model for tracking payments (Stripe, PayPal, and Crypto)
model Payment {
  id                String   @id @default(cuid())
  bookingId         String   @unique
  provider          String   @default("stripe") // stripe, paypal, crypto
  stripePaymentId   String?  @unique // Stripe PaymentIntent ID
  stripeSessionId   String?  @unique // Stripe Checkout Session ID
  paypalOrderId     String?  @unique // PayPal Order ID
  paypalCaptureId   String?  // PayPal Capture ID
  cryptoChargeId    String?  @unique // Coinbase Commerce Charge ID
  cryptoChargeCode  String?  // Coinbase Commerce Charge Code
  cryptoNetwork     String?  // bitcoin, ethereum, litecoin
  cryptoTxId        String?  // Blockchain transaction ID
  amount            Float    // Total amount charged to customer
  currency          String   @default("EUR")
  status            PaymentStatus @default(PENDING)
  paymentMethod     String?  // card, bank_transfer, paypal, crypto, etc.

  // Fee breakdown
  bookingAmount     Float?   // Original booking price (cleaner's rate)
  customerFee       Float?   // Fixed + percentage fee from customer
  cleanerFee        Float?   // Fixed + percentage fee from cleaner
  platformFee       Float?   // Total platform fee (customerFee + cleanerFee)
  cleanerPayout     Float?   // Amount transferred to cleaner
  receiptUrl        String?
  failureReason     String?
  refundedAmount    Float?
  refundedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  booking           Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

// Earnings model for tracking cleaner earnings
model Earning {
  id            String   @id @default(cuid())
  cleanerId     String
  bookingId     String   @unique
  amount        Float    // Amount earned (after platform fee)
  platformFee   Float    // Platform's cut
  grossAmount   Float    // Total payment received
  currency      String   @default("USD")
  status        EarningStatus @default(PENDING)
  availableAt   DateTime // When funds become available for payout
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cleaner       User     @relation("CleanerEarnings", fields: [cleanerId], references: [id])
  booking       Booking  @relation(fields: [bookingId], references: [id])
  payout        Payout?  @relation(fields: [payoutId], references: [id])
  payoutId      String?

  @@index([cleanerId])
  @@index([status])
}

// Custom category submitted by users
model Category {
  id          String   @id @default(cuid())
  name        String
  nameDE      String?  // German translation
  description String?
  emoji       String   @default("📁")
  gradient    String   @default("from-gray-400 to-gray-600")
  status      CategoryStatus @default(PENDING)
  submittedBy String?  // userId of submitter
  reviewedBy  String?  // admin userId who reviewed
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  professions Profession[]

  @@index([status])
}

// Professions within a category (what workers do)
model Profession {
  id          String   @id @default(cuid())
  categoryId  String?  // Optional - can be assigned later by admin
  name        String   @unique
  nameDE      String?  // German translation
  emoji       String   @default("👤")
  status      CategoryStatus @default(PENDING)  // PENDING until admin approves
  submittedBy String?  // userId of worker who suggested it
  reviewedBy  String?  // admin who approved/rejected
  reviewedAt  DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  workers     WorkerProfession[]

  @@index([categoryId])
  @@index([status])
}

// Junction table: Workers can have multiple professions
model WorkerProfession {
  id           String   @id @default(cuid())
  workerId     String   @map("cleanerId")
  professionId String
  isPrimary    Boolean  @default(false)  // Main profession shown first
  hourlyRate   Float?   // Rate for this specific profession (nullable for backwards compatibility)
  createdAt    DateTime @default(now())

  worker       WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  profession   Profession @relation(fields: [professionId], references: [id], onDelete: Cascade)

  @@unique([workerId, professionId])
  @@index([workerId])
  @@index([professionId])
  @@map("CleanerProfession")
}

// Payout model for tracking cleaner payouts
model Payout {
  id              String    @id @default(cuid())
  cleanerId       String
  amount          Float
  currency        String    @default("USD")
  status          PayoutStatus @default(PENDING)
  payoutMethod    String?   // bank_transfer, paypal, etc.
  stripePayoutId  String?   @unique
  failureReason   String?
  processedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  cleaner         User      @relation("CleanerPayouts", fields: [cleanerId], references: [id])
  earnings        Earning[]

  @@index([cleanerId])
  @@index([status])
}

// ============================================
// DISPUTE SYSTEM MODELS
// ============================================

model Dispute {
  id            String           @id @default(cuid())
  bookingId     String
  customerId    String
  cleanerId     String
  type          DisputeType
  status        DisputeStatus    @default(OPEN)
  subject       String
  description   String
  resolution    DisputeResolution?
  resolutionNote String?
  refundAmount  Float?
  resolvedById  String?
  resolvedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  booking       Booking          @relation(fields: [bookingId], references: [id])
  customer      User             @relation("CustomerDisputes", fields: [customerId], references: [id])
  cleaner       User             @relation("CleanerDisputes", fields: [cleanerId], references: [id])
  resolvedBy    User?            @relation("ResolvedDisputes", fields: [resolvedById], references: [id])
  messages      DisputeMessage[]
  evidence      DisputeEvidence[]

  @@index([customerId])
  @@index([cleanerId])
  @@index([status])
  @@index([bookingId])
}

model DisputeMessage {
  id          String   @id @default(cuid())
  disputeId   String
  senderId    String
  content     String
  isAdmin     Boolean  @default(false)
  createdAt   DateTime @default(now())

  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  sender      User     @relation("DisputeMessagesSent", fields: [senderId], references: [id])

  @@index([disputeId])
}

model DisputeEvidence {
  id          String   @id @default(cuid())
  disputeId   String
  uploaderId  String
  fileUrl     String
  fileName    String
  fileType    String
  fileSize    Int
  description String?
  createdAt   DateTime @default(now())

  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  uploader    User     @relation("DisputeEvidenceUploaded", fields: [uploaderId], references: [id])

  @@index([disputeId])
}

// ============================================
// NOTIFICATION MODELS
// ============================================

model NotificationPreference {
  id          String              @id @default(cuid())
  userId      String
  type        NotificationType
  channel     NotificationChannel
  enabled     Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user        User                @relation("NotificationPreferences", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, channel])
  @@index([userId])
}

model PushSubscription {
  id          String   @id @default(cuid())
  userId      String
  endpoint    String   @unique
  p256dh      String
  auth        String
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation("PushSubscriptions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NotificationLog {
  id          String              @id @default(cuid())
  userId      String
  type        NotificationType
  channel     NotificationChannel
  title       String
  body        String
  data        Json?
  sent        Boolean             @default(false)
  sentAt      DateTime?
  error       String?
  createdAt   DateTime            @default(now())

  user        User                @relation("NotificationLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model ReminderPreference {
  id                  String   @id @default(cuid())
  userId              String   @unique
  enabled             Boolean  @default(true)
  reminderTimes       Int[]    @default([1440, 60]) // Minutes before booking (1440=24hr, 60=1hr)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation("ReminderPreferences", fields: [userId], references: [id], onDelete: Cascade)
}

model BookingReminder {
  id                  String   @id @default(cuid())
  bookingId           String
  userId              String
  reminderMinutes     Int      // Minutes before booking this reminder was for
  sentAt              DateTime @default(now())
  channel             NotificationChannel

  booking             Booking  @relation("BookingReminders", fields: [bookingId], references: [id], onDelete: Cascade)
  user                User     @relation("BookingReminders", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bookingId, userId, reminderMinutes, channel])
  @@index([bookingId])
  @@index([userId])
}

// ============================================
// BOOKING CHANGE MODEL (Reschedule/Cancel)
// ============================================

model BookingChange {
  id                String              @id @default(cuid())
  bookingId         String
  requesterId       String
  type              BookingChangeType
  status            BookingChangeStatus @default(PENDING)
  reason            String?

  // For reschedule
  originalDate      DateTime?
  originalTime      String?
  newDate           DateTime?
  newTime           String?

  // For cancellation
  refundAmount      Float?
  refundPercent     Float?

  responderId       String?
  responseNote      String?
  respondedAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  booking           Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  requester         User                @relation("BookingChangeRequester", fields: [requesterId], references: [id])
  responder         User?               @relation("BookingChangeResponder", fields: [responderId], references: [id])

  @@index([bookingId])
  @@index([requesterId])
  @@index([status])
}

// ============================================
// BOOKING PHOTOS MODEL
// ============================================

model BookingPhoto {
  id          String   @id @default(cuid())
  bookingId   String
  uploaderId  String
  type        String   // "before" or "after"
  fileUrl     String
  thumbnailUrl String?
  fileName    String
  fileSize    Int
  caption     String?
  createdAt   DateTime @default(now())

  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  uploader    User     @relation("BookingPhotosUploaded", fields: [uploaderId], references: [id])

  @@index([bookingId])
  @@index([type])
}

// ============================================
// CLEANER DOCUMENT VERIFICATION MODEL
// ============================================

model WorkerDocument {
  id            String         @id @default(cuid())
  cleanerId     String
  type          DocumentType
  status        DocumentStatus @default(PENDING)
  fileUrl       String
  fileName      String
  fileSize      Int
  expiresAt     DateTime?
  verifiedById  String?
  verifiedAt    DateTime?
  rejectionNote String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  cleaner       User           @relation("CleanerDocuments", fields: [cleanerId], references: [id], onDelete: Cascade)
  verifiedBy    User?          @relation("DocumentsVerified", fields: [verifiedById], references: [id])

  @@index([cleanerId])
  @@index([status])
  @@index([type])
  @@map("CleanerDocument")
}

// ============================================
// CALENDAR SYNC MODELS
// ============================================

model CalendarConnection {
  id              String   @id @default(cuid())
  userId          String
  provider        String   // "google" or "outlook"
  email           String
  accessToken     String   // Encrypted
  refreshToken    String?  // Encrypted
  tokenExpiresAt  DateTime?
  calendarId      String?
  lastSyncAt      DateTime?
  syncEnabled     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation("CalendarConnections", fields: [userId], references: [id], onDelete: Cascade)
  events          CalendarEvent[]

  @@unique([userId, provider])
  @@index([userId])
}

model CalendarEvent {
  id              String   @id @default(cuid())
  connectionId    String
  bookingId       String?
  externalEventId String   // Google/Outlook event ID
  title           String
  description     String?
  startTime       DateTime
  endTime         DateTime
  location        String?
  lastSyncAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  connection      CalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  booking         Booking?           @relation(fields: [bookingId], references: [id])

  @@unique([connectionId, externalEventId])
  @@index([bookingId])
}

// ============================================
// ANALYTICS SNAPSHOT MODEL (Optional caching)
// ============================================

model AnalyticsSnapshot {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "cleaner" or "admin"
  period      String   // "daily", "weekly", "monthly"
  date        DateTime // Start of period
  data        Json
  createdAt   DateTime @default(now())

  user        User     @relation("AnalyticsSnapshots", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, period, date])
  @@index([userId])
  @@index([date])
}

// ============================================
// SECURITY MODELS
// ============================================

// Persistent audit log for security events
model AuditLog {
  id          String   @id @default(cuid())
  action      String   // e.g., "LOGIN_SUCCESS", "USER_DELETED", "PASSWORD_RESET"
  actorId     String?  // User who performed the action
  actorEmail  String?  // Email of actor (for when user is deleted)
  targetId    String?  // Resource affected
  targetType  String?  // e.g., "User", "Booking", "Payment"
  details     Json?    // Additional context (sanitized)
  ip          String?  // IP address
  userAgent   String?  // Browser/device info
  country     String?  // Geo-location country
  severity    String   @default("INFO") // INFO, WARNING, CRITICAL
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@index([severity])
}

// Active user sessions for session management
model UserSession {
  id            String    @id @default(cuid())
  userId        String
  sessionToken  String    @unique // JWT token hash or session ID
  deviceId      String?   // Link to known device
  ip            String?
  userAgent     String?
  country       String?
  city          String?
  lastActiveAt  DateTime  @default(now())
  expiresAt     DateTime
  isValid       Boolean   @default(true) // Can be revoked
  createdAt     DateTime  @default(now())

  user          User      @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)
  device        UserDevice? @relation(fields: [deviceId], references: [id])

  @@index([userId])
  @@index([sessionToken])
  @@index([isValid])
}

// Known user devices for fingerprinting
model UserDevice {
  id              String    @id @default(cuid())
  userId          String
  fingerprint     String    // Hash of device characteristics
  name            String?   // User-friendly name (e.g., "Chrome on Windows")
  browser         String?
  os              String?
  deviceType      String?   // desktop, mobile, tablet
  isTrusted       Boolean   @default(false) // User has verified this device
  lastSeenAt      DateTime  @default(now())
  lastIp          String?
  lastCountry     String?
  createdAt       DateTime  @default(now())

  user            User      @relation("UserDevices", fields: [userId], references: [id], onDelete: Cascade)
  sessions        UserSession[]

  @@unique([userId, fingerprint])
  @@index([userId])
}

// Email verification tokens
model EmailVerificationToken {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  expires     DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation("EmailVerifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ============================================
// SMART LOCK ENUMS
// ============================================

enum SmartLockProvider {
  AUGUST
  YALE
  SCHLAGE
  KWIKSET
  TTLOCK
  NUKI
  GENERIC
}

enum SmartLockAccessType {
  PERMANENT
  TEMPORARY
  ONE_TIME
}

enum SmartLockAccessStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

// ============================================
// PROPERTY MANAGEMENT MODEL
// ============================================

model Property {
  id          String   @id @default(cuid())
  ownerId     String
  name        String   // e.g., "Beach House", "Main Apartment"
  address     String
  city        String?
  state       String?
  postalCode  String?
  country     String?
  latitude    Float?
  longitude   Float?
  size        Int?     // Square meters
  rooms       Int?     // Number of rooms
  bathrooms   Int?     // Number of bathrooms
  notes       String?  // Special instructions
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User     @relation("UserProperties", fields: [ownerId], references: [id], onDelete: Cascade)
  bookings    Booking[]
  smartLocks  SmartLock[]

  @@index([ownerId])
}

// ============================================
// SMART LOCK MODELS
// ============================================

model SmartLock {
  id            String            @id @default(cuid())
  propertyId    String
  name          String            // e.g., "Front Door", "Back Door"
  provider      SmartLockProvider
  deviceId      String?           // External device ID from provider
  serialNumber  String?
  isActive      Boolean           @default(true)
  batteryLevel  Int?              // 0-100 percentage
  lastSyncAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  property      Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  accessCodes   SmartLockAccess[]

  @@index([propertyId])
}

model SmartLockAccess {
  id            String                @id @default(cuid())
  lockId        String
  bookingId     String?               // Optional link to booking
  cleanerId     String?               // Cleaner who has access
  accessType    SmartLockAccessType   @default(TEMPORARY)
  accessCode    String                // The PIN code or access token
  validFrom     DateTime
  validUntil    DateTime?             // Null for permanent access
  status        SmartLockAccessStatus @default(ACTIVE)
  usedAt        DateTime?             // When the code was first used
  usageCount    Int                   @default(0)
  maxUsage      Int?                  // Max times code can be used (null = unlimited)
  revokedAt     DateTime?
  revokedReason String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  lock          SmartLock             @relation(fields: [lockId], references: [id], onDelete: Cascade)

  @@index([lockId])
  @@index([bookingId])
  @@index([cleanerId])
  @@index([status])
}

// ============================================
// TEAM BOOKING MODEL
// ============================================

model BookingTeamMember {
  id          String   @id @default(cuid())
  bookingId   String
  cleanerId   String
  isLead      Boolean  @default(false)  // Primary cleaner is the lead
  confirmed   Boolean  @default(false)  // Team member has accepted
  earnings    Float?   // Individual earnings for this team member
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  cleaner     User     @relation("TeamMemberBookings", fields: [cleanerId], references: [id])

  @@unique([bookingId, cleanerId])
  @@index([bookingId])
  @@index([cleanerId])
}

// ============================================
// INVOICE MODEL
// ============================================

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique  // INV-2024-0001 format
  bookingId     String   @unique
  customerId    String
  cleanerId     String

  // Invoice details
  subtotal      Float
  tipAmount     Float    @default(0)
  taxRate       Float    @default(0)
  taxAmount     Float    @default(0)
  totalAmount   Float
  currency      String   @default("USD")

  // Service details (snapshot at invoice time)
  serviceName   String
  serviceDate   DateTime
  serviceTime   String
  duration      Int
  address       String

  // Status
  status        String   @default("ISSUED")  // ISSUED, PAID, CANCELLED
  paidAt        DateTime?
  sentAt        DateTime?
  sentTo        String?  // Email address

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  booking       Booking  @relation(fields: [bookingId], references: [id])
  customer      User     @relation("CustomerInvoices", fields: [customerId], references: [id])
  cleaner       User     @relation("CleanerInvoices", fields: [cleanerId], references: [id])

  @@index([customerId])
  @@index([cleanerId])
  @@index([invoiceNumber])
}

// ============================================
// GUARANTEE CLAIMS
// ============================================

model GuaranteeClaim {
  id            String   @id @default(cuid())

  // Relations
  bookingId     String
  customerId    String
  cleanerId     String

  // Claim details
  reason        GuaranteeClaimReason
  description   String   @db.Text
  evidence      String[] // Array of file URLs (photos, etc.)

  // Status tracking
  status        GuaranteeClaimStatus @default(PENDING)

  // Resolution
  resolution       GuaranteeResolution?
  resolutionNote   String?  @db.Text
  refundAmount     Float?
  resolvedAt       DateTime?
  resolvedById     String?

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  booking       Booking  @relation(fields: [bookingId], references: [id])
  customer      User     @relation("CustomerClaims", fields: [customerId], references: [id])
  cleaner       User     @relation("CleanerClaims", fields: [cleanerId], references: [id])
  resolvedBy    User?    @relation("ResolvedClaims", fields: [resolvedById], references: [id])

  @@index([bookingId])
  @@index([customerId])
  @@index([cleanerId])
  @@index([status])
}
