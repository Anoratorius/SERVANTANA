  token       String   @unique
  platform    String // "ios" or "android"
  deviceName  String?
  deviceModel String?
  appVersion  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

